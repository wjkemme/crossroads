{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure",
            "type": "shell",
            "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: build",
            "type": "shell",
            "command": "cmake --build build --config Debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Kill crossroads",
            "type": "shell",
            "command": "pkill -f './build/crossroads' 2>/dev/null; fuser -k 8080/tcp 2>/dev/null; sleep 0.3; echo 'Old processes cleaned up'",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "CMake: run",
            "type": "shell",
            "command": "./build/crossroads",
            "group": "none",
            "dependsOn": "Kill crossroads",
            "problemMatcher": []
        }
    ]
}